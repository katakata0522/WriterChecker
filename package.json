{
    "name": "writer-checker",
    "version": "1.0.0",
    "type": "module",
    "description": "レギュレーション・チェッカー — 文章の表記ユレやAI装飾をカスタムルールで一括チェック＆修正",
    "private": true,
    "scripts": {
        "build:css": "node scripts/build-css.mjs",
        "test": "node --test \"tests/*.test.mjs\"",
        "test:regression": "node --test \"tests/lighthouseFixes.test.mjs\" \"tests/perfOptimizations.test.mjs\" \"tests/regressionAutomation.test.mjs\"",
        "qa:gate": "npm run test && npm run test:regression && npm run build:css",
        "verify:prod": "node scripts/verify-production.mjs",
        "deploy:xserver": "powershell -ExecutionPolicy Bypass -File scripts/deploy-xserver.ps1"
    }
}
